#postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
# Use `disable` for the included local postgres service (no SSL by default).
# Use `require` or `verify-full` only when PostgreSQL TLS is configured.
DB_SSLMODE=disable

#PGadmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

JWT_SECRET="your_secret_key"